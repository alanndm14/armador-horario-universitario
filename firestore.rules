rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /admins/{uid} {
      allow read: if signedIn() && request.auth.uid == uid;
      allow write: if false;
    }

    match /courses/{courseId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();

      match /groups/{groupId} {
        allow read: if signedIn();
        allow create, update, delete: if isAdmin();
      }
    }

    match /users/{uid} {
      allow read, create, update: if signedIn() && request.auth.uid == uid;
      allow delete: if false;

      match /schedules/{scheduleId} {
        allow read, create, update, delete: if signedIn() && request.auth.uid == uid;
      }
    }

    match /syncRuns/{runId} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}
